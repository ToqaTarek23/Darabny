@model LessonFormViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
@section breadCrumb {
    <div class="page-breadcrumb">
        <div class="row">
            <div class="col-12 d-flex no-block align-items-center">
                <h4 class="page-title">Add Lesson</h4>
                <div class="ms-auto text-end">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/admin/lessons">Lessons</a></li>
                            <li class="breadcrumb-item active">Create</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>
}
@if (TempData["msg"] != null)
{
    <div class="alert alert-success"><i class="fas fa-circle-check me-2"></i>@TempData["msg"]</div>
}
<form method="post" asp-controller="AdminLesson" asp-action="Create">
    <div class="card-body">
        <div class="form-group row mb-3">
            <label class="col-sm-3 text-end col-form-label">Chapter <span class="text-danger">*</span></label>
            <div class="col-sm-9">
                <select asp-for="ChapterId" class="form-select">
                    <option value="0">-- Select Chapter --</option>
                    @foreach (var ch in Model.Chapters)
                    {
                        <option value="@ch.Id">@ch.Course?.Name — @ch.Name</option>
                    }
                </select>
                <span asp-validation-for="ChapterId" class="text-danger small"></span>
            </div>
        </div>
        <div class="form-group row mb-3">
            <label class="col-sm-3 text-end col-form-label">Lesson Title <span class="text-danger">*</span></label>
            <div class="col-sm-9">
                <input asp-for="Name" class="form-control" placeholder="e.g. Variables and Data Types">
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
        </div>
    </div>
    <div class="border-top">
        <div class="card-body d-flex gap-2">
            <button type="submit" class="btn btn-primary">Add Lesson</button>
            <a href="/admin/lessons" class="btn btn-secondary">Cancel</a>
        </div>
    </div>
</form>
