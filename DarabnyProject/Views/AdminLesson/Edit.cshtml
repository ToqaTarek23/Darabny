@model LessonFormViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
@section breadCrumb {
    <div class="page-breadcrumb">
        <div class="row">
            <div class="col-12 d-flex no-block align-items-center">
                <h4 class="page-title">Edit Lesson</h4>
                <div class="ms-auto text-end">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/admin/lessons">Lessons</a></li>
                            <li class="breadcrumb-item active">Edit</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>
}
<form method="post" action="/admin/lessons/edit">
    <input type="hidden" asp-for="Id" />
    <div class="card-body">
        <div class="form-group row mb-3">
            <label class="col-sm-3 text-end col-form-label">Chapter <span class="text-danger">*</span></label>
            <div class="col-sm-9">
                <select asp-for="ChapterId" class="form-select">
                    @foreach (var ch in Model.Chapters)
                    {
                        if (ch.Id == Model.ChapterId)
                        {
                            <option value="@ch.Id" selected="selected">@ch.Course?.Name — @ch.Name</option>
                        }
                        else
                        {
                            <option value="@ch.Id">@ch.Course?.Name — @ch.Name</option>
                        }
                    }
                </select>
                <span asp-validation-for="ChapterId" class="text-danger small"></span>
            </div>
        </div>
        <div class="form-group row mb-3">
            <label class="col-sm-3 text-end col-form-label">Lesson Title <span class="text-danger">*</span></label>
            <div class="col-sm-9">
                <input asp-for="Name" class="form-control">
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
        </div>
    </div>
    <div class="border-top">
        <div class="card-body d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a href="/admin/lessons" class="btn btn-secondary">Cancel</a>
        </div>
    </div>
</form>
