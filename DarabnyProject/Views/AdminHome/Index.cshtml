@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Admin Overview";
}
@section breadCrumb {
    <div class="page-breadcrumb">
        <div class="row">
            <div class="col-12 d-flex no-block align-items-center">
                <h4 class="page-title">Overview</h4>
            </div>
        </div>
    </div>
}
<div class="row g-3">
    <div class="col-md-3 col-sm-6">
        <a href="/admin/courses" class="text-decoration-none">
            <div class="card text-center p-3">
                <i class="fas fa-book-open fa-2x mb-2" style="color:var(--primary,#2563eb)"></i>
                <h5>Courses</h5>
                <p class="text-muted mb-0">Manage all courses</p>
            </div>
        </a>
    </div>
    <div class="col-md-3 col-sm-6">
        <a href="/admin/categories" class="text-decoration-none">
            <div class="card text-center p-3">
                <i class="fas fa-folder fa-2x mb-2" style="color:var(--primary,#2563eb)"></i>
                <h5>Categories</h5>
                <p class="text-muted mb-0">Manage categories</p>
            </div>
        </a>
    </div>
    <div class="col-md-3 col-sm-6">
        <a href="/admin/chapters" class="text-decoration-none">
            <div class="card text-center p-3">
                <i class="fas fa-list-ol fa-2x mb-2" style="color:var(--primary,#2563eb)"></i>
                <h5>Chapters</h5>
                <p class="text-muted mb-0">Manage chapters</p>
            </div>
        </a>
    </div>
    <div class="col-md-3 col-sm-6">
        <a href="/admin/lessons" class="text-decoration-none">
            <div class="card text-center p-3">
                <i class="fas fa-play-circle fa-2x mb-2" style="color:var(--primary,#2563eb)"></i>
                <h5>Lessons</h5>
                <p class="text-muted mb-0">Manage lessons</p>
            </div>
        </a>
    </div>
</div>
