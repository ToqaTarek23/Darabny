@model ChapterFormViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
@section breadCrumb {
    <div class="page-breadcrumb">
        <div class="row">
            <div class="col-12 d-flex no-block align-items-center">
                <h4 class="page-title">Edit Chapter</h4>
                <div class="ms-auto text-end">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/admin/chapters">Chapters</a></li>
                            <li class="breadcrumb-item active">Edit</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>
}
<form method="post" action="/admin/chapters/edit">
    <input type="hidden" asp-for="Id" />
    <div class="card-body">
        <div class="form-group row mb-3">
            <label class="col-sm-3 text-end col-form-label">Course <span class="text-danger">*</span></label>
            <div class="col-sm-9">
                <select asp-for="CourseId" class="form-select">
                    @foreach (var c in Model.Courses)
                    {
                        if (c.Id == Model.CourseId)
                        {
                            <option value="@c.Id" selected="selected">@c.Name</option>
                        }
                        else
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    }
                </select>
                <span asp-validation-for="CourseId" class="text-danger small"></span>
            </div>
        </div>
        <div class="form-group row mb-3">
            <label class="col-sm-3 text-end col-form-label">Chapter Title <span class="text-danger">*</span></label>
            <div class="col-sm-9">
                <input asp-for="Name" class="form-control">
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
        </div>
    </div>
    <div class="border-top">
        <div class="card-body d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a href="/admin/chapters" class="btn btn-secondary">Cancel</a>
        </div>
    </div>
</form>
