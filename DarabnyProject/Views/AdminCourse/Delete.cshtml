@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
@model DarabnyProject.Models.Course
<div class="container py-4">
    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-body d-flex align-items-center justify-content-center"
                     style="min-height:220px; background:#f0f4ff;">
                    <i class="mdi mdi-book-open-page-variant" style="font-size:5rem; opacity:.3;"></i>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <h2>@Model.Name</h2>
            <p><strong>Category:</strong> @(Model.Category?.Name ?? "-")</p>
            <p><strong>Price:</strong> @(Model.PriceType == DarabnyProject.Enums.PriceType.Free ? "Free" : $"EGP {Model.Price:0}")</p>
            <p>@Model.Description</p>

            <div class="alert alert-danger mt-3">
                Are you sure you want to delete this course? All its chapters and lessons will also be deleted.
            </div>
            <div class="d-flex gap-2">
                <form method="post">
                    <input type="submit" value="Yes, Delete" class="btn btn-danger" />
                </form>
                <a class="btn btn-secondary" href="/admin/courses">Cancel</a>
            </div>
        </div>
    </div>
</div>
