@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
@model DarabnyProject.Models.Course
<div class="container py-4">
    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-body d-flex align-items-center justify-content-center"
                     style="min-height:220px; background:#f0f4ff;">
                    <i class="mdi mdi-book-open-page-variant" style="font-size:5rem; opacity:.3;"></i>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <h2>@Model.Name</h2>
            <p><strong>Category:</strong> @(Model.Category?.Name ?? "-")</p>
            <p><strong>Level:</strong> @Model.Level</p>
            <p><strong>Language:</strong> @Model.Language</p>
            <p><strong>Price:</strong> @(Model.PriceType == DarabnyProject.Enums.PriceType.Free ? "Free" : $"EGP {Model.Price:0}")</p>
            <p><strong>Length:</strong> @Model.CourseLength hrs</p>
            <p><strong>Last Updated:</strong> @Model.LastUpdated.ToString("dd MMM yyyy")</p>
            <p>@Model.Description</p>

            @if (Model.Requirements != null && Model.Requirements.Any())
            {
                <h6>Requirements</h6>
                <ul>
                    @foreach (var r in Model.Requirements)
                    {
                        <li>@r.Requirement</li>
                    }
                </ul>
            }
            @if (Model.WhatWillLearn != null && Model.WhatWillLearn.Any())
            {
                <h6>What Students Will Learn</h6>
                <ul>
                    @foreach (var w in Model.WhatWillLearn)
                    {
                        <li>@w.Objective</li>
                    }
                </ul>
            }
            @if (Model.Chapters != null && Model.Chapters.Any())
            {
                <h6>Chapters</h6>
                @foreach (var ch in Model.Chapters)
                {
                    <p><strong>@ch.Name</strong> — @(ch.Lessons?.Count ?? 0) lesson(s)</p>
                }
            }
        </div>
    </div>
    <div class="d-flex gap-2 mt-3">
        <a class="btn btn-success" href="/admin/courses/edit/@Model.Id">Edit</a>
        <a class="btn btn-danger"  href="/admin/courses/delete/@Model.Id">Delete</a>
        <a class="btn btn-secondary" href="/admin/courses">Back to List</a>
    </div>
</div>
