@model CourseFormViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
@section breadCrumb {
    <div class="page-breadcrumb">
        <div class="row">
            <div class="col-12 d-flex no-block align-items-center">
                <h4 class="page-title">Add Course</h4>
                <div class="ms-auto text-end">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/admin/courses">Courses</a></li>
                            <li class="breadcrumb-item active">Create</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>
}
@if (TempData["msg"] != null)
{
    <div class="alert alert-success"><i class="fas fa-circle-check me-2"></i>@TempData["msg"]</div>
}
<form method="post" asp-controller="AdminCourse" asp-action="Create">
    <div class="card-body">

        <div class="form-group row mb-3">
            <label class="col-sm-3 text-end col-form-label">Title <span class="text-danger">*</span></label>
            <div class="col-sm-9">
                <input asp-for="Name" class="form-control" placeholder="Course title">
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
        </div>

        <div class="form-group row mb-3">
            <label class="col-sm-3 text-end col-form-label">Category <span class="text-danger">*</span></label>
            <div class="col-sm-9">
                <select asp-for="CategoryId" class="form-select">
                    <option value="0">-- Select Category --</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                </select>
                <span asp-validation-for="CategoryId" class="text-danger small"></span>
            </div>
        </div>

        <div class="form-group row mb-3">
            <label class="col-sm-3 text-end col-form-label">Instructor</label>
            <div class="col-sm-9">
                <select asp-for="InstructorId" class="form-select">
                    <option value="0">-- No Instructor --</option>
                    @foreach (var inst in Model.Instructors)
                    {
                        <option value="@inst.Id">@inst.Name</option>
                    }
                </select>
                <small class="text-muted">Only active Teachers appear here.</small>
            </div>
        </div>

        <div class="form-group row mb-3">
            <label class="col-sm-3 text-end col-form-label">Level</label>
            <div class="col-sm-9">
                <select asp-for="Level" class="form-select">
                    <option value="0">Beginner</option>
                    <option value="1">Intermediate</option>
                    <option value="2">Advanced</option>
                </select>
            </div>
        </div>

        <div class="form-group row mb-3">
            <label class="col-sm-3 text-end col-form-label">Language</label>
            <div class="col-sm-9">
                <input asp-for="Language" class="form-control">
            </div>
        </div>

        <div class="form-group row mb-3">
            <label class="col-sm-3 text-end col-form-label">Price (EGP) — 0 = Free</label>
            <div class="col-sm-9">
                <input asp-for="Price" class="form-control" type="number" min="0" step="1">
                <span asp-validation-for="Price" class="text-danger small"></span>
            </div>
        </div>

        <div class="form-group row mb-3">
            <label class="col-sm-3 text-end col-form-label">Length (hours)</label>
            <div class="col-sm-9">
                <input asp-for="CourseLength" class="form-control" type="number" min="0" step="1">
            </div>
        </div>

        <div class="form-group row mb-3">
            <label class="col-sm-3 text-end col-form-label">Description <span class="text-danger">*</span></label>
            <div class="col-sm-9">
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Short course description"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>
        </div>

        <div class="form-group row mb-3">
            <label class="col-sm-3 text-end col-form-label">
                Requirements<br><small class="text-muted">(one per line)</small>
            </label>
            <div class="col-sm-9">
                <textarea asp-for="RequirementsText" class="form-control" rows="3"
                          placeholder="No prior experience needed&#10;A computer with internet"></textarea>
            </div>
        </div>

        <div class="form-group row mb-3">
            <label class="col-sm-3 text-end col-form-label">
                What Will We Learn<br><small class="text-muted">(one per line)</small>
            </label>
            <div class="col-sm-9">
                <textarea asp-for="LearnText" class="form-control" rows="3"
                          placeholder="Build real-world projects&#10;Understand core concepts"></textarea>
            </div>
        </div>

    </div>
    <div class="border-top">
        <div class="card-body d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-plus me-1"></i> Add Course
            </button>
            <a href="/admin/courses" class="btn btn-secondary">Cancel</a>
        </div>
    </div>
</form>
