<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Darabny Admin</title>
    <link rel="stylesheet" href="~/css/site.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&family=Manrope:wght@500;700;800&display=swap" rel="stylesheet">
    @RenderSection("Styles", required: false)
</head>
<body class="dashboard-theme">

    <!-- Navbar -->
    <nav class="navbar navbar-expand-xl page-navbar">
        <div class="container-fluid px-3">
            <a class="brand" href="/">
                <img src="~/img/logo.png" alt="Darabny"><span>Darabny</span>
            </a>
            <button class="navbar-toggler border-0 shadow-none" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbar" aria-label="toggle">
                <i class="fas fa-bars text-white fs-5"></i>
            </button>
            <div class="collapse navbar-collapse" id="navbar">
                <ul class="navbar-nav ms-auto me-3">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/Courses">Courses</a></li>
                </ul>
                <div class="d-flex align-items-center gap-2">
                    <span class="login-chip" id="adminUserLabel" style="display:none;"></span>
                    <a class="login-chip" href="/Account/Login" id="adminLoginLink">Login</a>
                    <button class="login-chip border-0" type="button" id="adminLogoutBtn" style="display:none;">Logout</button>
                </div>
            </div>
        </div>
    </nav>

    <div class="admin-wrapper">

        <!-- Sidebar -->
        <aside class="admin-sidebar">
            <div class="sidebar-heading">Dashboard</div>
            <a href="/admin" class="@(Context.Request.Path == "/admin" ? "active" : "")">
                <i class="fas fa-home fa-fw"></i>
                @if (User.IsInRole("Admin")) { <text>Admin Overview</text> }
                else { <text>Instructor Overview</text> }
            </a>

            <div class="sidebar-heading">Catalog</div>
            <a href="/admin/courses"
               class="@(Context.Request.Path.StartsWithSegments("/admin/courses") ? "active" : "")">
                <i class="fas fa-book-open fa-fw"></i> Courses
            </a>
            @if (User.IsInRole("Admin"))
            {
                <a href="/admin/categories"
                   class="@(Context.Request.Path.StartsWithSegments("/admin/categories") ? "active" : "")">
                    <i class="fas fa-folder fa-fw"></i> Categories
                </a>
            }

            <div class="sidebar-heading">Content</div>
            <a href="/admin/chapters"
               class="@(Context.Request.Path.StartsWithSegments("/admin/chapters") ? "active" : "")">
                <i class="fas fa-list-ol fa-fw"></i> Chapters
            </a>
            <a href="/admin/lessons"
               class="@(Context.Request.Path.StartsWithSegments("/admin/lessons") ? "active" : "")">
                <i class="fas fa-play-circle fa-fw"></i> Lessons
            </a>
        </aside>

        <!-- Main Content -->
        <main class="admin-content">
            @if (IsSectionDefined("breadCrumb"))
            {
                @RenderSection("breadCrumb")
            }

            <div class="card">
                <div class="card-body">
                    @RenderBody()
                </div>
            </div>
        </main>
    </div>

    <!-- Footer -->
    <footer class="footer-modern" style="margin-top:0;">
        <div class="container">
            <div class="footer-bottom">
                <p>© 2026 Darabny Admin Panel. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="~/js/auth.js"></script>
    <script src="~/js/theme-toggle.js"></script>
    <script>
        $(document).ready(function () {
            if ($('#zero_config').length) {
                $('#zero_config').DataTable();
            }
        });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
