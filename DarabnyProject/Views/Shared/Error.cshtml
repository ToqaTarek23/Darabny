@{
    ViewData["Title"] = "Error";
    Layout = "_CustomerLayout";
}

<section class="section">
    <div class="panel" style="text-align:center; padding: 5rem 2rem;">
        <i class="fa-solid fa-circle-exclamation fa-4x mb-4" style="color: var(--primary);"></i>
        <h2>Oops! Something went wrong.</h2>
        <p>An unexpected error occurred. Please try again later.</p>
        <a class="btn-primary-modern mt-3" asp-controller="Home" asp-action="Index">Go Back Home</a>
    </div>
</section>
