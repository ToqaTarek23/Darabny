@{
    ViewData["Title"] = "About Us";
    ViewData["ActivePage"] = "About";
    Layout = "_CustomerLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css">
}

<section class="section">
        <div class="panel about-panel">
            <div class="about-layout">
                <aside class="about-intro-card">
                    <p class="about-tag">Our Identity</p>
                    <h2>Learning That Moves You Forward</h2>
                    <p>Darabny was built to turn passive learning into practical action through guided paths, projects, and mentor feedback.</p>
                    <div class="about-mini-stats">
                        <article>
                            <h3>12K+</h3>
                            <p>Learners</p>
                        </article>
                        <article>
                            <h3>340+</h3>
                            <p>Courses</p>
                        </article>
                        <article>
                            <h3>45+</h3>
                            <p>Mentors</p>
                        </article>
                    </div>
                </aside>

                <div class="about-content-flow">
                    <article class="about-step">
                        <span class="step-no">01</span>
                        <div>
                            <h3>Our Vision</h3>
                            <p>To become the top practical learning platform in the Arab region with measurable career outcomes.</p>
                        </div>
                    </article>

                    <article class="about-step">
                        <span class="step-no">02</span>
                        <div>
                            <h3>Our Mission</h3>
                            <p>Empower students with job-ready technical and business skills through hands-on, project-based learning.</p>
                        </div>
                    </article>

                    <article class="about-step">
                        <span class="step-no">03</span>
                        <div>
                            <h3>How We Teach</h3>
                            <p>Structured roadmaps, project milestones, and clear checkpoints that keep learners moving with confidence.</p>
                        </div>
                    </article>
                </div>
            </div>

            <div class="about-ribbon-grid mt-3">
                <article class="ribbon-card">
                    <h4>What Makes Us Different</h4>
                    <ul>
                        <li>Clear learning paths from beginner to advanced.</li>
                        <li>Real projects to build strong portfolios.</li>
                        <li>Mentor support and practical guidance.</li>
                        <li>Skills aligned with market demand.</li>
                    </ul>
                </article>

                <article class="ribbon-card">
                    <h4>Who We Serve</h4>
                    <ul>
                        <li>Students starting their career journey.</li>
                        <li>Professionals upskilling or changing careers.</li>
                        <li>Instructors sharing practical expertise.</li>
                        <li>Teams looking for focused training tracks.</li>
                    </ul>
                </article>
            </div>
        </div>
    </section>